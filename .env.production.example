# BBAS — Production environment variables
#
# Copy to your hosting provider's secret store (Vercel: Project → Settings →
# Environment Variables → Production). Do NOT commit a populated copy of this
# file to git. Server-side keys (SUPABASE_SERVICE_ROLE_KEY, GEMINI_API_KEY,
# RESEND_API_KEY) must NEVER be set as `NEXT_PUBLIC_*` — they would leak into
# the client bundle.

# -----------------------------------------------------------------------------
# Supabase (project must be in production mode with RLS enabled)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-prod-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...your-service-role-key

# -----------------------------------------------------------------------------
# Gemini AI (Google)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key

# -----------------------------------------------------------------------------
# Resend (transactional email)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_...

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# Public URL of the production deployment — used for email links etc.
NEXT_PUBLIC_APP_URL=https://bbas.vercel.app
NEXT_PUBLIC_DEFAULT_LOCALE=bn
NODE_ENV=production
